{
  "name": "todo-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --packages=external --outfile=dist/index.js",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc",
    "migrate": "knex migrate:latest",
    "migrate:down": "knex migrate:down",
    "migrate:reset": "knex migrate:rollback --all"
  },
  "dependencies": {
    "@hono/node-server": "^1.18.1",
    "bcrypt": "^6.0.0",
    "hono": "^4.9.1",
    "knex": "^3.2.8",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.5",
    "typescript": "~5.9.3"
  }
}
