    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "~5.9.3"
  }
